def main():
    run_ts        = datetime.now().strftime("%Y%m%d_%H%M%S")
    log, log_path = setup_logging(run_ts)
    timer         = Timer(log)
    dev           = DevArtifacts(run_ts, log)

    log.info("=" * 60)
    log.info("ELOG CONDITIONS REPORT v7 — START")
    log.info(f"Run ID    : {run_ts}")
    log.info(f"Excel     : {EXCEL_PATH}")
    log.info(f"Model     : {MODEL_PATH}")
    log.info(f"Shift     : {SHIFT_START_HOUR:02d}:00–{SHIFT_END_HOUR:02d}:00  "
             f"date={SHIFT_DATE or 'auto'}")
    log.info(f"n_threads : {N_THREADS}  n_batch={N_BATCH}  "
             f"n_ctx={LLM_CONFIG['n_ctx']}  f16_kv={LLM_CONFIG['f16_kv']}")
    log.info(f"Dev mode  : {'ON → ' + str(Path(DEV_DIR)/run_ts) if DEV_MODE else 'OFF'}")
    log.info("=" * 60)

    # ── Load ──────────────────────────────────────────────────────────────────
    try:
        df = load_elog(EXCEL_PATH, SHEET_NAME, log)
    except FileNotFoundError:
        log.critical(f"Excel not found: {EXCEL_PATH}"); sys.exit(1)
    except Exception as e:
        log.critical(f"Load failed: {e}", exc_info=True); sys.exit(1)
    timer.split("Load Excel")

    # ── Shift filter + prepare ────────────────────────────────────────────────
    df_shift    = filter_shift(df, log)
    shift_label = (f"{SHIFT_DATE or datetime.now().date()} "
                   f"{SHIFT_START_HOUR:02d}:00–{SHIFT_END_HOUR:02d}:00")
    dev.raw_shift_rows(df_shift)

    records = prepare_rows(df_shift, log)
    dev.prepared_rows(records)
    timer.split("Filter + prepare")

    # ── MAP PHASE: Tier 1 + Tier 2 ────────────────────────────────────────────
    t1_skipped, after_t1 = tier1_rules(records, log)
    dev.tier1_output(t1_skipped, after_t1)
    timer.split("Tier 1 — rule engine")

    t2_skipped, candidates = tier2_keywords(after_t1, log)
    dev.tier2_output(t2_skipped, candidates)
    timer.split("Tier 2 — keyword triage")

    all_skipped = t1_skipped + t2_skipped
    pct     = len(candidates) / max(len(records), 1) * 100
    est_min = len(candidates) / max(LLM_BATCH_SIZE, 1) * 15 / 60
    log.info(f"Map phase complete: {len(all_skipped):,} skipped  "
             f"{len(candidates):,} candidates ({pct:.1f}%)  "
             f"est Step1={est_min:.0f}min")

    dev.candidates(candidates)

    # ── STEP 1: analyze_entry.prompty ─────────────────────────────────────────
    analyzed = []
    if candidates:
        if not os.path.exists(MODEL_PATH):
            log.critical(f"Model not found: {MODEL_PATH}"); sys.exit(1)

        log.info("Loading LLM for Step 1 (analyze_entry) …")
        llm     = Llama(model_path=MODEL_PATH, **LLM_CONFIG)
        grammar = LlamaGrammar.from_string(ENTRY_GBNF)
        log.info("Model + GBNF grammar loaded ✓")
        timer.split("Load LLM")

        analyzed = run_analyze_entry(llm, grammar, candidates, log, dev)
        del llm; del grammar; gc.collect()
        timer.split("Step 1 — analyze_entry")
    else:
        log.info("No candidates — Step 1 skipped")

    dev.llm_results(analyzed)

    # ── Merge all records ─────────────────────────────────────────────────────
    all_records = all_skipped + analyzed
    included    = [r for r in all_records if r.get("should_include")]
    groups      = {"CRITICAL":[], "HIGH":[], "MEDIUM":[], "LOW":[]}
    for r in included:
        p = r.get("priority","LOW")
        if p in groups: groups[p].append(r)

    stats = {
        "total":      len(records),
        "skipped":    len(all_skipped),
        "candidates": len(candidates),
    }

    log.info(f"Included: {len(included):,}  "
             f"CRITICAL={len(groups['CRITICAL'])}  "
             f"HIGH={len(groups['HIGH'])}  "
             f"MED={len(groups['MEDIUM'])}  "
             f"LOW={len(groups['LOW'])}  "
             f"IESO={sum(1 for g in groups.values() for e in g if e.get('ieso_notified'))}")

    write_audit_csv(all_records, run_ts, log)

    # ── STEP 2: executive_summary.prompty ─────────────────────────────────────
    log.info("Loading LLM for Step 2 (executive_summary) …")
    sum_llm = Llama(model_path=MODEL_PATH, **LLM_CONFIG)
    log.info("Model loaded ✓")
    timer.split("Load LLM summary")

    summary = generate_executive_summary(sum_llm, groups, shift_label, log, dev)
    del sum_llm; gc.collect()
    timer.split("Step 2 — executive_summary")

    # ── Save ──────────────────────────────────────────────────────────────────
    out = save_report(summary, groups, all_records, shift_label, stats, log, run_ts)
    timer.split("Save report")

    dev.print_index()

    total_s = timer.total()
    log.info("=" * 60)
    log.info(f"DONE — {int(total_s)//60}m {int(total_s)%60}s")
    log.info(f"Report → {out}")
    log.info(f"Log    → {log_path}")
    if DEV_MODE:
        log.info(f"Dev    → {Path(DEV_DIR)/run_ts}/")
    log.info("=" * 60)


if __name__ == "__main__":
    main()
