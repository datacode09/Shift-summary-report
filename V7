# ── GBNF grammar for analyze_entry JSON output ────────────────────────────────
# Constrains token sampling so invalid JSON is physically impossible.
# Eliminates all parse failures and retries.
ENTRY_GBNF = r"""
root   ::= "[" ws entry ("," ws entry)* ws "]"
entry  ::= "{" ws
           "\"id\""                     ws ":" ws number      ws ","  ws
           "\"should_include\""         ws ":" ws boolean     ws ","  ws
           "\"summary\""               ws ":" ws string      ws ","  ws
           "\"priority\""              ws ":" ws priority     ws ","  ws
           "\"ieso_notified\""         ws ":" ws boolean     ws ","  ws
           "\"ieso_notification_time\"" ws ":" ws time-or-null
           ws "}"
priority     ::= "\"CRITICAL\"" | "\"HIGH\"" | "\"MEDIUM\"" | "\"LOW\""
time-or-null ::= "null" | "\"" [0-9] [0-9] ":" [0-9] [0-9] "\""
boolean      ::= "true" | "false"
string       ::= "\"" ( [^"\\] | "\\" ["\\/bfnrt] )* "\""
number       ::= [0-9]+
ws           ::= [ \t\n]*
"""
